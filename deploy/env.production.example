# /var/www/bukdoo/backend/.env 로 복사 후 값 채우기 (systemd EnvironmentFile)
# 절대 git 에 커밋하지 말 것

FLASK_ENV=production
FLASK_DEBUG=False

# DB (같은 서버 MariaDB 공유 — reward_db + 전용계정 bukdoo)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=bukdoo
DB_PASSWORD=여기에_DB_강력한_비밀번호
DB_NAME=bukdoo_db

# JWT 시크릿 (아래 명령으로 생성해서 붙여넣기)
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=여기에_48바이트_이상_랜덤값

# 프론트와 같은 도메인(HTTPS)이면 동일 출처라 사실상 불필요하지만 명시 권장
CORS_ORIGINS=https://thundersui.com,https://www.thundersui.com
